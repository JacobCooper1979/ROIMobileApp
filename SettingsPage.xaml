<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ROI_app.SettingsPage"
             Title="SettingsPage">
    <VerticalStackLayout>
        <Grid>
            <!-- Background image -->
            <Image
            Source="burnt_orange_texture_image.png"
            Aspect="AspectFill"
            HorizontalOptions="FillAndExpand"
            VerticalOptions="FillAndExpand" />

            <StackLayout>
                <!-- Header section with Home button and logo -->
                <StackLayout
                Orientation="Horizontal"
                Margin="10">
                    <Button
                    x:Name="Home"
                    Text="HOME"
                    AutomationProperties.HelpText="Navigates back to the home button"
                    BackgroundColor= "#941a1d"
                    TextColor="Black"
                    HeightRequest="110"
                    WidthRequest="150"
                    FontSize="30"
                    Clicked="OnHomeButtonClicked"/>

                    <Image
                    Source="roi_logo.png"
                    AutomationProperties.Name="ROI logo"
                    HeightRequest="200"
                    WidthRequest="200"
                    Margin="10, 0, 20, 0"
                    VerticalOptions="Start"
                    HorizontalOptions="End"
                    Grid.Row="0" />

                    <!-- Welcome label -->
                    <Label
                    Text="Welcome to ROI application. Please select an option."
                    FontSize="30"
                    TextColor="Black"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    HorizontalTextAlignment="Center" />

                </StackLayout>

                <!-- Welcome label -->
                <Label
                Text="Welcome to ROI application. Please select an option."
                FontSize="30"
                TextColor="Black"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                HorizontalTextAlignment="Center" />

                <!-- Buttons section -->
                <StackLayout>












                </StackLayout>

            </StackLayout>
        </Grid>
    </VerticalStackLayout>
    
</ContentPage>